Bash Analyze all April/July/June/Aug rows for anomalies
IN
python -c "
import sys, io
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')
import csv
from pathlib import Path

DATA_DIR = Path(r'C:\Users\whyke\github\six-problem\Data')

COL_NAMES = [
    'eye1',
    'P1_prob','P1_sol','P1_r1','P1_eval','P1_type','P1_r2',
    'P2_prob','P2_sol','P2_r1','P2_eval','P2_type','P2_r2',
    'P3_prob','P3_sol','P3_r1','P3_eval','P3_type','P3_r2',
    'P4_prob','P4_sol','P4_r1','P4_eval','P4_type','P4_r2',
    'P5_prob','P5_sol','P5_r1','P5_eval','P5_type','P5_r2',
    'P6_prob','P6_sol','P6_r1','P6_eval','P6_type','P6_r2',
    'eye2'
]

with open(DATA_DIR / 'EEG_Segmentation(Sheet1).csv', encoding='latin-1') as f:
    reader = csv.reader(f)
    next(reader)
    rows = {r[0].strip(): [x.strip() for x in r[3:41]] for r in reader if r[0].strip()}

targets = [
    'April_2(1).xlsx','april_02(3).xlsx',
    'april_04(1).xlsx','April_04(2).xlsx',
    'april_08.xlsx','April_15.xlsx','April_16(1).xlsx',
    'april_16(3).xlsx','april_18(1).xlsx','april_18(2).xlsx',
    'april_19(1).xlsx','April_19(2).xlsx',
    'april_22.xlsx','april_24.xlsx',
    'July_29.xlsx','July_30.xlsx','June_25.xlsx','aug_05.xlsx'
]

print('=== ANOMALY CHECK: 每列对照 ===\n')
print(f'{\"File\":<22} {\"eye1\":>4} {\"P1\":>12} {\"P2\":>12} {\"P3\":>12} {\"P4\":>12} {\"P5\":>12} {\"P6\":>12} {\"eye2\":>4}  Issues')
print('-'*140)

for name in targets:
    seq = rows.get(name, [])
    if not seq or len(seq) < 38:
        continue
    
    def g(i): return seq[i] if i < len(seq) else '?'
    
    issues = []
    vals = [g(i) for i in range(38)]
    nums = [int(v) if v.isdigit() else None for v in vals]
    
    # Check duplicates
    filled = [v for v in vals if v]
    dupes = [v for v in filled if filled.count(v) > 1]
    if dupes:
        issues.append(f'DUPE:{list(set(dupes))}')
    
    # Check reverse order
    prev = None
    for i, n in enumerate(nums):
        if n is not None and prev is not None and n < prev:
            issues.append(f'REVERSE@col{i}({prev}->{n})')
        if n is not None:
            prev = n
    
    # Large gaps (>3) within a problem
    for p in range(6):
        start = 1 + p*6
        prob_vals = [nums[start+j] for j in range(6)]
        filled_prob = [v for v in prob_vals if v is not None]
        if len(filled_prob) >= 2:
            for i in range(len(filled_prob)-1):
                if filled_prob[i+1] - filled_prob[i] > 3:
                    issues.append(f'P{p+1}gap({filled_prob[i]}->{filled_prob[i+1]})')
    
    p1 = f'{g(1)},{g(2)},{g(3)},{g(4)},{g(5)},{g(6)}'
    p2 = f'{g(7)},{g(8)},{g(9)},{g(10)},{g(11)},{g(12)}'
    p3 = f'{g(13)},{g(14)},{g(15)},{g(16)},{g(17)},{g(18)}'
    p4 = f'{g(19)},{g(20)},{g(21)},{g(22)},{g(23)},{g(24)}'
    p5 = f'{g(25)},{g(26)},{g(27)},{g(28)},{g(29)},{g(30)}'
    p6 = f'{g(31)},{g(32)},{g(33)},{g(34)},{g(35)},{g(36)}'
    
    issue_str = ' | '.join(issues) if issues else 'OK'
    print(f'{name:<22} {g(0):>4} {p1:>12} {p2:>12} {p3:>12} {p4:>12} {p5:>12} {p6:>12} {g(37):>4}  {issue_str}')
" 2>&1

