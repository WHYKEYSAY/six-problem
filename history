import sys, io
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')
import csv
from pathlib import Path

DATA_DIR = Path(r'C:\Users\whyke\github\six-problem\Data')

with open(DATA_DIR / 'EEG_Segmentation(Sheet1).csv', encoding='latin-1') as f:
    reader = csv.reader(f)
    headers = next(reader)
    rows = list(reader)

# Print April and July rows with full marker sequences
targets = ['april', 'july', 'june', 'aug']
for row in rows:
    name = row[0].strip().lower()
    if not any(t in name for t in targets):
        continue
    if not row[1].strip():
        continue
    markers = [x.strip() for x in row[3:] if x.strip() != '']
    blanks = sum(1 for x in row[3:41] if x.strip() == '')
    print(f'{row[0].strip():<22} total={row[1].strip():<4} markers={len(markers):<3} blanks={blanks:<3}')
    print(f'  seq: {[x.strip() for x in row[3:41]]}')
    print()
