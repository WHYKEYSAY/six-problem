Bash Process July_30 and June_25 with -1 marker correction
IN
python -c "
import sys, io
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')
import csv, mne
from pathlib import Path

DATA_DIR   = Path(r'C:\Users\whyke\github\six-problem\Data')
OUTPUT_DIR = DATA_DIR / 'segments_output'
LOCS_PATH  = DATA_DIR / 'Cap63 (1).locs'
CSV_PATH   = DATA_DIR / 'EEG_Segmentation_correction.csv'

# File paths
FILE_MAP = {
    'July_30.xlsx': DATA_DIR / 'OneDrive_1_09-04-2026/eeg_July_30/july_30.vhdr',
    'June_25.xlsx': DATA_DIR / 'OneDrive_1_09-04-2026/june_25_eeg/june_25.vhdr',
}

SEG_LABELS = [
    'eye_closed_1',
    'P1_prob','P1_sol','P1_rate1','P1_eval','P1_type','P1_rate2',
    'P2_prob','P2_sol','P2_rate1','P2_eval','P2_type','P2_rate2',
    'P3_prob','P3_sol','P3_rate1','P3_eval','P3_type','P3_rate2',
    'P4_prob','P4_sol','P4_rate1','P4_eval','P4_type','P4_rate2',
    'P5_prob','P5_sol','P5_rate1','P5_eval','P5_type','P5_rate2',
    'P6_prob','P6_sol','P6_rate1','P6_eval','P6_type','P6_rate2',
    'eye_closed_2',
]

# Read CSV markers and apply -1 correction
subjects = {}
with open(CSV_PATH, encoding='latin-1') as f:
    reader = csv.reader(f)
    next(reader)
    for row in reader:
        name = row[0].strip()
        if name not in FILE_MAP:
            continue
        raw_vals = [v.strip() for v in row[3:41]]
        markers = []
        for v in raw_vals:
            if v == '' or v.upper() == 'NA':
                markers.append(None)
            elif v.isdigit():
                markers.append(int(v) - 1)  # APPLY -1 CORRECTION
            else:
                markers.append(None)
        subjects[name] = markers

print('=== CORRECTED MARKERS (-1 applied) ===')
for name, markers in subjects.items():
    nums = [m for m in markers if m is not None]
    print(f'{name}: range {min(nums)}-{max(nums)}, {len(nums)} filled')
    print(f'  {markers}')
    print()

# Preprocess + segment
for csv_name, markers in subjects.items():
    vhdr = FILE_MAP[csv_name]
    folder = csv_name.replace('.xlsx','').replace('(','_').replace(')','').replace(' ','_')
    out_dir = OUTPUT_DIR / folder
    out_dir.mkdir(parents=True, exist_ok=True)

    print(f'Processing {csv_name}...')
    raw = mne.io.read_raw_brainvision(str(vhdr), preload=True, verbose='ERROR')
    raw.filter(0.5, 40.0, method='fir', verbose=False)
    raw.set_eeg_reference('average', projection=False, verbose=False)

    events, _ = mne.events_from_annotations(raw, verbose=False)
    event_times = events[:, 0] / raw.info['sfreq']
    print(f'  EEG events: {len(event_times)}, duration: {raw.times[-1]:.1f}s')

    ok = 0
    for i, label in enumerate(SEG_LABELS):
        m_start = markers[i]
        m_end = next((markers[j] for j in range(i+1, len(markers)) if markers[j] is not None), None)

        if m_start is None:
            print(f'  ⬜ {label:<20} SKIP (missing marker)')
            continue

        idx_s = m_start - 1  # 1-based → 0-based
        if idx_s < 0 or idx_s >= len(event_times):
            print(f'  ✗ {label:<20} OUT OF RANGE (marker {m_start})')
            continue

        t_start = event_times[idx_s]
        if m_end is not None and (m_end-1) < len(event_times):
            t_end = event_times[m_end - 1]
        else:
            t_end = raw.times[-1]

        seg = raw.copy().crop(tmin=t_start, tmax=t_end)
        out_file = out_dir / f'{label}.fif'
        seg.save(str(out_file), overwrite=True, verbose=False)
        print(f'  ✓ {label:<20} {t_end - t_start:.1f}s → {out_file.name}')
        ok += 1

    print(f'  Done: {ok}/{len(SEG_LABELS)} segments saved to {out_dir.name}/')
    print()

print('Finished.')
" 2>&1

