python -c "
import sys, io
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')
import csv
from pathlib import Path

DATA_DIR = Path(r'C:\Users\whyke\github\six-problem\Data')

with open(DATA_DIR / 'EEG_Segmentation(Sheet1).csv', encoding='latin-1') as f:
    reader = csv.reader(f)
    next(reader)
    rows = {r[0].strip(): [x.strip() for x in r[3:41]] for r in reader if r[0].strip()}

def analyze(name, seq):
    print(f'\n【{name}】')
    labels = ['eye1',
        'P1_prob','P1_sol','P1_r1','P1_eval','P1_type','P1_r2',
        'P2_prob','P2_sol','P2_r1','P2_eval','P2_type','P2_r2',
        'P3_prob','P3_sol','P3_r1','P3_eval','P3_type','P3_r2',
        'P4_prob','P4_sol','P4_r1','P4_eval','P4_type','P4_r2',
        'P5_prob','P5_sol','P5_r1','P5_eval','P5_type','P5_r2',
        'P6_prob','P6_sol','P6_r1','P6_eval','P6_type','P6_r2','eye2']
    
    nums = [int(v) if v.isdigit() else None for v in seq]
    
    issues = []
    prev_num = None
    prev_label = None
    for i, (label, n, v) in enumerate(zip(labels, nums, seq)):
        if n is None and v == '':
            issues.append(f'  ⬜ BLANK: {label}')
        elif n is not None and prev_num is not None:
            gap = n - prev_num
            if gap == 0:
                issues.append(f'  🔴 DUPLICATE: {label}={n} (same as {prev_label}={prev_num})')
            elif gap > 2:
                issues.append(f'  🟡 GAP +{gap}: {prev_label}={prev_num} → {label}={n} (skipped {list(range(prev_num+1,n))})')
        if n is not None:
            prev_num = n
            prev_label = label
    
    if issues:
        for iss in issues:
            print(iss)
    else:
        print('  ✓ No anomalies detected')

problem_files = [
    'April_2(1).xlsx',
    'April_19(2).xlsx',
    'april_22.xlsx',
    'april_02(3).xlsx',
    'July_29.xlsx',
    'aug_05.xlsx',
]

print('=' * 70)
print('DETAILED ANOMALY REPORT (April / July / Aug)')
print('=' * 70)

for name in problem_files:
    seq = rows.get(name, [])
    if seq:
        analyze(name, seq)

print()
